{
  "name": "home-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run subset-font && vite",
    "build": "npm run subset-font && npm run validate:tank90 && tsc -p tsconfig.json --noEmit && vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "build:gh-pages": "tsc -p tsconfig.json --noEmit && vite build && cp dist/index.html dist/404.html",
    "subset-font": "npx tsx scripts/extract-resume-chars.ts > scripts/resume-chars.txt && npx tsx scripts/subset-font.ts",
    "test:e2e": "playwright test",
    "validate:tank90": "npx tsx scripts/validate-tank90-levels.ts",
    "sync:tank90-maps": "node scripts/sync-nes-battlecity-terrain.mjs"
  },
  "dependencies": {
    "@fontsource/open-sans": "^5.2.7",
    "@supabase/supabase-js": "^2.100.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "subset-font": "^2.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.2"
  }
}
